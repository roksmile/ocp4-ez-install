#!/usr/bin/env bash
# =============================================================================
# config.env - OCP4 Air-Gap Installation Common Configuration
# =============================================================================
# connected/ 및 air-gapped/ 스크립트 공통 환경설정 파일
# 환경에 맞게 아래 값들을 수정하여 사용하세요.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenShift 버전 설정
# -----------------------------------------------------------------------------
export OCP_VERSION="4.20.16"
export OCP_MAJOR_VERSION="4.20"
export OCP_CHANNEL="stable-4.20"

# -----------------------------------------------------------------------------
# 클러스터 기본 설정
# -----------------------------------------------------------------------------
export CLUSTER_NAME="kscada"          # 클러스터 이름 (ISC 디렉토리 이름으로 사용)
export BASE_DOMAIN="kdneri.com"           # 클러스터 베이스 도메인

# -----------------------------------------------------------------------------
# 디렉토리 설정
# -----------------------------------------------------------------------------
# 이 config.env 파일이 위치한 디렉토리를 BASE_DIR 로 설정
export BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export DOWNLOAD_DIR="${BASE_DIR}/downloads"        # 도구 다운로드 디렉토리
export MIRROR_DIR="${BASE_DIR}/mirror"             # oc-mirror 결과물 저장 디렉토리
export CACHE_DIR="${BASE_DIR}/cache"               # oc-mirror 캐시 디렉토리 (하위에 target별 디렉토리 생성)
export LOG_DIR="${BASE_DIR}/logs"                  # 로그 파일 디렉토리

# 클러스터별 ISC 파일 저장 디렉토리 (connected/, air-gapped/ 와 동일 레벨)
export CLUSTER_DIR="${BASE_DIR}/${CLUSTER_NAME}"

# -----------------------------------------------------------------------------
# Mirror Registry 설정 (air-gap 환경용)
# -----------------------------------------------------------------------------
export MIRROR_REGISTRY_HOST="ocp-registry.kscada.kdneri.com"             # 예: registry.example.com
export MIRROR_REGISTRY_PORT="5000"
export MIRROR_REGISTRY="${MIRROR_REGISTRY_HOST}:${MIRROR_REGISTRY_PORT}"

# Mirror Registry 인증 정보
export MIRROR_REGISTRY_USER="admin"
export MIRROR_REGISTRY_PASS="redhat"

# -----------------------------------------------------------------------------
# 인증서 Subject DN 기본값 (02_create_certs.sh 에서 사용)
# -----------------------------------------------------------------------------
export CERT_C="KR"
export CERT_ST="Seoul"
export CERT_L="Gangnam"
export CERT_O="Red Hat"
export CERT_OU="GPS"

export CERTS_DIR="${BASE_DIR}/certs"   # 인증서 저장 디렉토리

# -----------------------------------------------------------------------------
# 인증 설정
# -----------------------------------------------------------------------------
# Red Hat Pull Secret 파일 경로
# https://console.redhat.com/openshift/install/pull-secret 에서 다운로드
export PULL_SECRET_FILE="${BASE_DIR}/pull-secret.txt"

# registry.redhat.io 인증을 위한 Service Account Token (선택사항)
# pull-secret 파일이 있으면 별도 설정 불필요
export REDHAT_REGISTRY_USER=""
export REDHAT_REGISTRY_PASS=""

# -----------------------------------------------------------------------------
# 다운로드 URL
# -----------------------------------------------------------------------------
export OCP_MIRROR_BASE="https://mirror.openshift.com/pub/openshift-v4/x86_64/clients"
export OCP_CLIENT_URL="${OCP_MIRROR_BASE}/ocp/${OCP_VERSION}"
export BUTANE_URL="${OCP_MIRROR_BASE}/butane/latest/butane-amd64"

# Helm
export HELM_VERSION="3.17.1"
export HELM_URL="https://developers.redhat.com/content-gateway/file/pub/openshift-v4/clients/helm/${HELM_VERSION}/helm-linux-amd64.tar.gz"

# -----------------------------------------------------------------------------
# Operator Catalog 주소
# -----------------------------------------------------------------------------
export REDHAT_OPERATOR_INDEX="registry.redhat.io/redhat/redhat-operator-index:v${OCP_MAJOR_VERSION}"
export CERTIFIED_OPERATOR_INDEX="registry.redhat.io/redhat/certified-operator-index:v${OCP_MAJOR_VERSION}"
export COMMUNITY_OPERATOR_INDEX="registry.redhat.io/redhat/community-operator-index:v${OCP_MAJOR_VERSION}"

# -----------------------------------------------------------------------------
# Operator 그룹 정의
# -----------------------------------------------------------------------------
# 형식: "operator-name:catalog"
#   catalog 값: redhat | certified | community
#   redhat    → REDHAT_OPERATOR_INDEX
#   certified → CERTIFIED_OPERATOR_INDEX
#   community → COMMUNITY_OPERATOR_INDEX
#
# 스크립트에서 파싱 예시:
#   for entry in "${GPU_OPERATORS[@]}"; do
#       op="${entry%%:*}"       # operator 이름
#       catalog="${entry##*:}"  # catalog 이름
#   done
# -----------------------------------------------------------------------------

# 선택 가능한 Operator 그룹 목록 (interactive 선택 순서)
# 형식: "group_id:설명"
OPERATOR_GROUPS=(
    "base:기본 Operator"
    "gpu:GPU Operator (NFD, NVIDIA GPU/Network)"
    "virt:가상화 Operator (KubeVirt, LSO, MTV 등)"
    "cicd:CI/CD Operator (GitOps, Pipelines, RHBK 등)"
    "developerhub:DeveloperHub 의존성 Operator (login,serverless 등)"
)
export OPERATOR_GROUPS

# Base Operators - ISC 생성 시 항상 포함 (선택 없이 자동 추가)
# 필요에 따라 추가/수정하세요.
BASE_OPERATORS=(
    "web-terminal:redhat"
    "kubernetes-nmstate-operator:redhat"
    "node-healthcheck-operator:redhat"
    "self-node-remediation:redhat"
    "cincinnati-operator:redhat"
    "cluster-logging:redhat"
    "devworkspace-operator:redhat"
    "loki-operator:redhat"
    "netobserv-operator:redhat"
    "metallb-operator:redhat"
    "lvms-operator:redhat"
    "local-storage-operator:redhat"
)
export BASE_OPERATORS

# GPU Operators
GPU_OPERATORS=(
    "nfd:redhat"
    "gpu-operator-certified:certified"
    "nvidia-network-operator:certified"
)
export GPU_OPERATORS

# Virtualization Operators
VIRT_OPERATORS=(
    "kubevirt-hyperconverged:redhat"
    "mtc-operator:redhat"
    "mtv-operator:redhat"
    "fence-agents-remediation:redhat"
)
export VIRT_OPERATORS

# CI/CD Operators
CICD_OPERATORS=(
    "openshift-gitops-operator:redhat"
    "rhbk-operator:redhat"
    "openshift-pipelines-operator-rh:redhat"
)
export CICD_OPERATORS

# DeveloperHub Operators
DEVELOPERHUB_OPERATORS=(
    "rhdh:redhat"
    "serverless-operator:redhat"
    "logic-operator:redhat"
)
export DEVELOPERHUB_OPERATORS
# -----------------------------------------------------------------------------
# Add Operators - 운영 중인 클러스터에 추가할 Operator 목록 (add-operators/ 스크립트에서 사용)
# 형식: "operator-name:catalog"  (기존 OPERATORS 배열과 동일 형식)
#   catalog 값: redhat | certified | community
# -----------------------------------------------------------------------------
ADD_OPERATORS_LIST=(
    "elasticsearch-eck-operator-certified:certified"
    "amq-streams:redhat"
)
export ADD_OPERATORS_LIST

ADD_OPERATORS_TARGET="lvm"
export ADD_OPERATORS_TARGET

# add-operators 결과물 저장 디렉토리
export ADD_OPERATORS_MIRROR_DIR="${BASE_DIR}/mirror-added"
export ADD_OPERATORS_CACHE_DIR="${BASE_DIR}/cache-added"

# Additional Images (ISC additionalImages 섹션에 포함될 추가 이미지 목록)
# 필요에 따라 추가/수정하세요.
ADDITIONAL_IMAGES=(
    "registry.redhat.io/ubi8/ubi:latest"
    "registry.redhat.io/ubi9/ubi:latest"
    "registry.redhat.io/rhel8/postgresql-15:latest"
    "registry.redhat.io/rhel8/postgresql-16:latest"
    "registry.redhat.io/rhel9/postgresql-15:latest"
    "registry.redhat.io/rhel9/postgresql-16:latest"
)
export ADDITIONAL_IMAGES

# -----------------------------------------------------------------------------
# 노드 정의 (agent-based install 용)
# -----------------------------------------------------------------------------
# 형식: "role|hostname|ip|nic|mac"
#   role     : master 또는 worker
#   hostname : 노드 호스트명 (짧은 이름, FQDN 아님)
#   ip       : 노드 IP 주소
#   nic      : 설치에 사용할 NIC 이름 (예: ens3, bond0, eth0)
#   mac      : NIC MAC 주소 (예: 52:54:00:aa:bb:cc)
NODES=(
    "master|master0.kscada.kdneri.com|192.168.100.10|enp1s0|52:54:00:aa:bb:01"
    "master|master1.kscada.kdneri.com|192.168.100.11|enp1s0|52:54:00:aa:bb:02"
    "master|master2.kscada.kdneri.com|192.168.100.12|enp1s0|52:54:00:aa:bb:03"
    "worker|worker0.kscada.kdneri.com|192.168.100.20|enp1s0|52:54:00:aa:bb:04"
    "worker|worker1.kscada.kdneri.com|192.168.100.21|enp1s0|52:54:00:aa:bb:05"
)
export NODES

# 추가할 노드 목록 (add-nodes/ 스크립트에서 사용)
# 형식: "role|hostname|ip|nic|mac"  (NODES 와 동일 형식, 보통 worker 만 추가)
ADD_NODES=(
    "worker|worker2.kscada.kdneri.com|192.168.100.22|enp1s0|52:54:00:aa:bb:06"
    "worker|worker3.kscada.kdneri.com|192.168.100.23|enp1s0|52:54:00:aa:bb:07"
)
export ADD_NODES

# -----------------------------------------------------------------------------
# 네트워크 설정
# -----------------------------------------------------------------------------
# machine_network: 노드 IP 가 속한 실제 네트워크 대역
export MACHINE_NETWORK="192.168.100.0/24"

# 기본 게이트웨이 IP
export GATEWAY="192.168.100.1"

# DNS 서버 목록 (배열, 순서대로 적용)
DNS_SERVERS=(
    "192.168.100.1"
)
export DNS_SERVERS

# NTP 서버 (Agent-Based Install: agent-config.yaml 의 additionalNTPSources 로 반영)
# 호스트명 또는 IP. 비우려면 NTP_SERVERS=() 로 두면 해당 섹션은 생성되지 않습니다.
# install-config.yaml 단독으로는 NTP를 넣을 수 없습니다 (platform: none 기준).
NTP_SERVERS=(
    "10.60.1.21"
    "10.60.1.22"
)
export NTP_SERVERS

# cluster_network: OCP 내부 Pod 네트워크 (기본값 권장)
export CLUSTER_NETWORK_CIDR="10.128.0.0/14"
export CLUSTER_NETWORK_HOST_PREFIX="23"

# service_network: OCP Service 네트워크 (기본값 권장)
export SERVICE_NETWORK="172.30.0.0/16"

# -----------------------------------------------------------------------------
# SSH 키 설정 (노드 core 계정 접속용)
# -----------------------------------------------------------------------------
# core 계정에 등록할 SSH 공개 키 (ssh-keygen 으로 생성 후 공개 키 내용을 붙여넣기)
SSH_PUB_KEY=(
    "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBQ/NSEJaZEprH5WwIOgVKkZp77uUYI5oDQxSLrN37dG root@bastion01.kscada.kdneri.com"
    "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIOtgnxZxNjAcVww3VvdkoQlGgnLDmI6CmjmJIn5bmgU6 cloud@bastion01.kscada.kdneri.com"
)
export SSH_PUB_KEY

# =============================================================================
# 내부 변수 (수정 불필요)
# =============================================================================
export LOG_FILE="${LOG_DIR}/ocp4-ez-install-$(date +%Y%m%d-%H%M%S).log"

# 다운로드 대상 파일 목록 (OCP Tools)
OCP_TOOL_FILES=(
    "openshift-client-linux-amd64-rhel9.tar.gz"
    "oc-mirror.rhel9.tar.gz"
    "openshift-install-linux.tar.gz"
    "opm-linux-rhel9.tar.gz"
)
export OCP_TOOL_FILES
